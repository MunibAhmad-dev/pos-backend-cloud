# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_characters
JWT_EXPIRES_IN=7d

# One-time key to create the very first admin account via POST /api/auth/setup
ADMIN_SETUP_KEY=setup_osatech_2025

# ── Database (local PostgreSQL on VPS) ────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Replace DB_USER, DB_PASS, and DB_NAME with your values (set in setup.sh)
DATABASE_URL="postgresql://osatech_user:your_strong_password@localhost:5432/pos_cloud_db"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add every origin that calls this API. Separate with commas. No trailing slash.
# Use * to allow all origins (safe since auth is JWT / API key protected).
ALLOWED_ORIGINS=*
