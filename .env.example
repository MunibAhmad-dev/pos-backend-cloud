# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ── Security ─────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Change before deploying!
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# One-time key used only to create the very first admin account via POST /api/auth/setup
ADMIN_SETUP_KEY=setup_osatech_2025

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# From neon.tech → Project → Connection Details
#
# DATABASE_URL  → use the POOLED connection string (for runtime queries)
# DIRECT_URL    → use the NON-POOLED (direct) connection string (for migrations)
#
# The pooled URL has "-pooler" in the hostname, the direct one does not.
# Example:
#   Pooled:  ep-xxx-pooler.region.neon.tech
#   Direct:  ep-xxx.region.neon.tech          ← just remove "-pooler"
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API (your admin dashboard URL)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
