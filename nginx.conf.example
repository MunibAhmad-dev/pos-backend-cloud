# ── OsaTech POS Backend — Nginx reverse proxy ────────────────────────────────
# Copy to: /etc/nginx/sites-available/pos-backend
# Then:    sudo ln -s /etc/nginx/sites-available/pos-backend /etc/nginx/sites-enabled/
#          sudo nginx -t && sudo systemctl reload nginx
#
# Replace YOUR_VPS_IP_OR_DOMAIN with your actual IP or domain name.
# ─────────────────────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name YOUR_VPS_IP_OR_DOMAIN;

    # Allow large installer uploads (POS .exe builds) via /api/admin/releases/upload.
    # Must be >= your installer size; default nginx limit is only 1 MB.
    client_max_body_size 600m;

    location / {
        proxy_pass         http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # ── Timeouts ────────────────────────────────────────────────────────
        # proxy_read_timeout: how long nginx waits for Express to respond
        # AFTER the full request body has been received.  60 s is too short
        # for large installer uploads — bumped to 600 s to match send/body.
        proxy_read_timeout    600s;
        proxy_send_timeout    600s;
        client_body_timeout   600s;

        # ── Large installer uploads ──────────────────────────────────────────
        # Disable request buffering so nginx streams the body to Express in
        # real-time rather than buffering on disk first.  Without this, nginx
        # may drop the upload mid-stream when the temp buffer fills up.
        proxy_request_buffering off;
    }
}

# ── HTTPS (run certbot first, it will auto-add the ssl block) ─────────────────
# sudo apt install certbot python3-certbot-nginx -y
# sudo certbot --nginx -d YOUR_DOMAIN
